# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/

# Data (EEG recordings are large and shouldn't live in git)
data/raw/
data/processed/
*.fif
*.edf
*.set
*.bdf

# Notebooks
.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/
.idea/

# Results (raw/intermediate results shouldn't live in git — they're
# regenerated by scripts/, and are often large or run-specific)
results/*.png
results/*.csv
results/*.json
results/*.npz
# ...except the final SHAP plots referenced directly in the README —
# these are small, meaningful, and worth being visible on GitHub
# without anyone needing to regenerate them first.
!results/shap_band_importance.png
!results/shap_channel_topomap.png
!results/.gitkeep
!data/.gitkeep
